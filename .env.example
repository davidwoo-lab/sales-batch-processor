# ===== DB 접속 정보 =====
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===== 메일(SMTP) 발송 계정 =====
# Gmail 사용 시 앱 비밀번호(App Password)를 발급받아 사용
MAIL_USERNAME=your_email@gmail.com
MAIL_APP_PASSWORD=your_app_password

# ===== 결과 리포트 수신자 =====
REPORT_RECIPIENT=manager@example.com

# ===== CSV 적재 경로 =====
# 스케줄러가 {CSV_IMPORT_PATH}/{yyyy-MM-dd}.csv 형식으로 전날 파일을 읽는다
CSV_IMPORT_PATH=/data/sales/import
